# Go binaries and test output
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
bin/

# Go workspace cache
.go-work-cache/

# Build and distribution output
dist/
build/

# Embedded frontend build (generated by pnpm build, not committed)
apps/piholsterd/internal/api/dist/*
!apps/piholsterd/internal/api/dist/.gitkeep

# Node
node_modules/
.pnpm-store/
.turbo/

# SvelteKit
.svelte-kit/
apps/web/build/

# Environment files
.env
.env.*

# SQLite databases
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Logs
*.log

# Temporary working directory
tmp/

# Raspberry Pi SD-card images
*.img
*.img.xz
*.img.xz.sha256
*.img.xz.minisig

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Release artefacts
release/

# Secrets — private keys only.
# minisign.pub is the PUBLIC half and is distributed via docs/minisign.pub
# so users can verify image signatures. Do NOT add it here.
*.pem
*.key
minisign.sec

# Local Docker overrides
docker-compose.override.yml
